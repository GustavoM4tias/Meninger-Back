<div style="max-width:600px;margin:0 auto;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#111827">

  <!-- Header info -->
  <div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:12px;padding:16px 20px;margin-bottom:24px">
    <h2 style="font-size:18px;font-weight:700;margin:0 0 8px;color:#111827">{{meetingSubject}}</h2>
    <div style="font-size:12px;color:#6b7280">
      {{#if meetingDate}}<span style="margin-right:12px">📅 {{meetingDate}}</span>{{/if}}
      {{#if durationMin}}<span style="margin-right:12px">⏱ {{durationMin}} min</span>{{/if}}
      {{#if organizerName}}<span>👤 {{organizerName}}</span>{{/if}}
    </div>
    {{#if tags}}
    <div style="margin-top:10px">
      {{#each tags}}
      <span style="background:#ede9fe;color:#6d28d9;padding:2px 8px;border-radius:9999px;font-size:11px;margin-right:4px">#{{this}}</span>
      {{/each}}
    </div>
    {{/if}}
  </div>

  {{#if observations}}
  <!-- Observações do remetente -->
  <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:10px;padding:14px 18px;margin-bottom:24px">
    <p style="font-size:12px;font-weight:700;color:#0369a1;margin:0 0 6px;text-transform:uppercase;letter-spacing:0.05em">Observação</p>
    <p style="font-size:13px;color:#0c4a6e;margin:0;line-height:1.6">{{observations}}</p>
  </div>
  {{/if}}

  {{#if resumo}}
  <!-- Resumo -->
  <div style="margin-bottom:24px">
    <h3 style="font-size:12px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 10px;padding-bottom:6px;border-bottom:2px solid #e5e7eb">📋 Resumo Executivo</h3>
    <p style="font-size:13px;color:#374151;line-height:1.7;margin:0">{{resumo}}</p>
  </div>
  {{/if}}

  {{#if decisoes}}
  <!-- Decisões -->
  <div style="margin-bottom:24px">
    <h3 style="font-size:12px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 10px;padding-bottom:6px;border-bottom:2px solid #e5e7eb">✅ Decisões Tomadas</h3>
    {{#each decisoes}}
    <div style="display:flex;gap:10px;padding:8px 0;border-bottom:1px solid #f3f4f6;font-size:13px;color:#374151;align-items:flex-start">
      <span style="color:#f59e0b;margin-top:2px;flex-shrink:0">●</span>
      <span>{{this}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if acoes}}
  <!-- Ações -->
  <div style="margin-bottom:24px">
    <h3 style="font-size:12px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 10px;padding-bottom:6px;border-bottom:2px solid #e5e7eb">⚡ Ações &amp; Responsabilidades</h3>
    <table style="width:100%;border-collapse:collapse;font-size:13px">
      <thead>
        <tr style="background:#f9fafb">
          <th style="text-align:left;padding:8px 10px;border-bottom:2px solid #e5e7eb;font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase">Tarefa</th>
          <th style="text-align:left;padding:8px 10px;border-bottom:2px solid #e5e7eb;font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase">Responsável</th>
          <th style="text-align:left;padding:8px 10px;border-bottom:2px solid #e5e7eb;font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase">Prazo</th>
        </tr>
      </thead>
      <tbody>
        {{#each acoes}}
        <tr>
          <td style="padding:8px 10px;border-bottom:1px solid #f3f4f6;color:#374151">{{descricao}}</td>
          <td style="padding:8px 10px;border-bottom:1px solid #f3f4f6;color:#6b7280">{{responsavel}}</td>
          <td style="padding:8px 10px;border-bottom:1px solid #f3f4f6;color:#6b7280">{{prazo}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{#if proximosPassos}}
  <!-- Próximos passos -->
  <div style="margin-bottom:24px">
    <h3 style="font-size:12px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 10px;padding-bottom:6px;border-bottom:2px solid #e5e7eb">➡️ Próximos Passos</h3>
    {{#each proximosPassos}}
    <div style="display:flex;gap:10px;padding:8px 0;border-bottom:1px solid #f3f4f6;font-size:13px;color:#374151;align-items:flex-start">
      <span style="color:#6d28d9;font-weight:700;flex-shrink:0">{{@index}}.</span>
      <span>{{this}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if pontosAtencao}}
  <!-- Pontos de atenção -->
  <div style="margin-bottom:24px">
    <h3 style="font-size:12px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 10px;padding-bottom:6px;border-bottom:2px solid #e5e7eb">⚠️ Pontos de Atenção</h3>
    {{#each pontosAtencao}}
    <div style="background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:10px 14px;margin-bottom:6px;font-size:13px;color:#9a3412">{{this}}</div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Aviso IA -->
  <div style="background:#fefce8;border:1px solid #fde68a;border-radius:8px;padding:10px 14px;margin-bottom:20px;font-size:11px;color:#92400e;line-height:1.5">
    ⚠️ <strong>Conteúdo gerado por inteligência artificial.</strong> Este relatório pode conter imprecisões ou omissões. Recomendamos revisar as informações antes de utilizá-las.
  </div>

  <!-- Footer -->
  <div style="text-align:center;padding-top:16px;border-top:1px solid #e5e7eb;font-size:11px;color:#9ca3af">
    Relatório gerado por <strong>Menin Office AI</strong>
    {{#if reportGeneratedAt}}&nbsp;·&nbsp;{{reportGeneratedAt}}{{/if}}
  </div>

</div>
