<h2 style="margin:0 0 8px 0;">{{title}}</h2>
{{#if preview}}
  <p class="muted" style="margin:0 0 12px 0; color:#6b7280;">{{preview}}</p>
{{/if}}
{{#if bodyHtml}}
  <div style="margin:16px 0; padding:16px; background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size:14px; line-height:1.6; color:#111827; white-space:pre-wrap; word-wrap:break-word;">{{{bodyHtml}}}</div>
{{else if body}}
  <pre style="margin:16px 0; padding:16px; background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size:14px; line-height:1.6; color:#111827; white-space:pre-wrap; word-wrap:break-word;">{{body}}</pre>
{{/if}}
{{#if description}}
  <p style="margin:0 0 16px 0;">{{description}}</p>
{{/if}}
